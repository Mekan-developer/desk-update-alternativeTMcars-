meta {
  name: Смена номера — шаг 2 (подтверждение)
  type: http
  seq: 6
}

post {
  url: {{base_url}}/v1/profile/phone/confirm
  body: json
}

headers {
  Accept: application/json
  Accept-Language: ru
  Authorization: Bearer {{token}}
}

body:json {
  {
    "phone": "+99365999888",
    "code": "000000"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
