meta {
  name: Карточка ролика
  type: http
  seq: 4
}

get {
  url: {{base_url}}/v1/videos/1
  body: none
}

headers {
  Accept: application/json
  Accept-Language: ru
}

docs {
  Переход к ролику (экран 9). Чужие pending/rejected-ролики — 404;
  владелец видит свой ролик в любом статусе (нужен Bearer-токен).
  Просмотр карточки счётчик не увеличивает — для этого POST /videos/{id}/view.
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
